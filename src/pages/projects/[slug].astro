---
import Layout from "../../layouts/Layout.astro";
import Carousel from "../../components/Carousel.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
	const projects = await getCollection("projects");
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, description, heroImage, images, platform, link, tags, pubDate } =
	project.data;
---

<Layout title={`${title} | Marcel Maatkamp`} description={description}>
	<article class="project-page">
		<div class="hero">
			{
				images && images.length > 0 ? (
					<Carousel
						images={images}
						id={`carousel-${project.id}`}
						autoPlay={true}
						interval={4000}
					/>
				) : heroImage ? (
					<img src={heroImage} alt={title} class="hero-image" />
				) : null
			}
		</div>

		<div class="container">
			<div class="project-header">
				<div class="back-link-wrap">
					<a href="/portfolio" class="back-link">← Portfolio</a>
				</div>
				<div class="title-row">
					<h1>{title}</h1>
					{platform && <span class="platform-badge">{platform}</span>}
				</div>
				<p class="lead">{description}</p>
				<div class="actions">
					{
						link && (
							<a href={link} target="_blank" rel="noopener" class="btn btn-play">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="20"
									height="20"
									viewBox="0 0 24 24"
									fill="currentColor"
								>
									<path d="M3 20.5v-17c0-.83 1-.83 1.5-.5l14 8.5c.5.29.5 1.21 0 1.5l-14 8.5c-.5.33-1.5.33-1.5-.5z" />
								</svg>
								View on Google Play
							</a>
						)
					}
				</div>
				{
					tags && tags.length > 0 && (
						<div class="tags">
							{tags.map((tag) => (
								<span class="tag">{tag}</span>
							))}
						</div>
					)
				}
			</div>

			<div class="project-content card">
				<Content />
			</div>
		</div>
	</article>
</Layout>

<style>
	.project-page {
		padding-bottom: var(--space-16);
	}

	.hero {
		width: 100%;
		max-height: 480px;
		overflow: hidden;
		margin-bottom: var(--space-8);
	}

	.hero-image {
		width: 100%;
		max-height: 480px;
		object-fit: cover;
		border-radius: 0;
	}

	.container {
		max-width: 900px;
		margin: 0 auto;
		padding: 0 var(--space-4);
	}

	.back-link-wrap {
		margin-bottom: var(--space-4);
	}

	.back-link {
		color: var(--color-text-muted);
		font-size: 0.9rem;
		transition: color var(--transition-fast);
	}

	.back-link:hover {
		color: var(--color-primary);
	}

	.title-row {
		display: flex;
		align-items: center;
		gap: var(--space-4);
		flex-wrap: wrap;
		margin-bottom: var(--space-2);
	}

	.title-row h1 {
		margin: 0;
	}

	.platform-badge {
		background-color: var(--color-primary);
		color: white;
		font-size: 0.75rem;
		padding: 3px 10px;
		border-radius: var(--radius-full);
		text-transform: uppercase;
		font-weight: 600;
		letter-spacing: 0.05em;
	}

	.lead {
		color: var(--color-text-muted);
		font-size: 1.15rem;
		margin: var(--space-4) 0;
		line-height: 1.7;
	}

	.actions {
		display: flex;
		gap: var(--space-4);
		margin: var(--space-6) 0;
	}

	.btn-play {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		padding: var(--space-3) var(--space-6);
		background: linear-gradient(135deg, #00c853, #00e676);
		color: #000;
		font-weight: 700;
		border-radius: var(--radius-md);
		font-size: 1rem;
		box-shadow: 0 4px 20px rgba(0, 200, 83, 0.4);
		transition: all var(--transition-fast);
	}

	.btn-play:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 25px rgba(0, 200, 83, 0.6);
		color: #000;
	}

	.tags {
		display: flex;
		gap: var(--space-2);
		flex-wrap: wrap;
		margin-bottom: var(--space-8);
	}

	.tag {
		background-color: var(--color-surface-hover);
		padding: 3px 10px;
		border-radius: var(--radius-full);
		font-size: 0.8rem;
		color: var(--color-text-muted);
	}

	.project-content {
		line-height: 1.8;
		font-size: 1.05rem;
	}

	.project-content :global(h2),
	.project-content :global(h3) {
		margin-top: var(--space-8);
		margin-bottom: var(--space-4);
		color: #fff;
	}

	.project-content :global(h2) {
		font-size: 1.5rem;
		border-bottom: 1px solid var(--color-border);
		padding-bottom: var(--space-2);
	}

	.project-content :global(h3) {
		font-size: 1.2rem;
		color: var(--color-primary);
	}

	.project-content :global(p) {
		margin-bottom: var(--space-4);
		color: var(--color-text-muted);
	}

	.project-content :global(ul),
	.project-content :global(ol) {
		padding-left: var(--space-6);
		margin-bottom: var(--space-4);
		color: var(--color-text-muted);
	}

	.project-content :global(li) {
		margin-bottom: var(--space-2);
	}

	.project-content :global(strong) {
		color: var(--color-text);
	}

	.project-content :global(a) {
		color: var(--color-primary);
	}

	.project-content :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin-bottom: var(--space-6);
		font-size: 0.95rem;
	}

	.project-content :global(th) {
		background: var(--color-surface-hover);
		padding: var(--space-3) var(--space-4);
		text-align: left;
		color: #fff;
		font-weight: 600;
	}

	.project-content :global(td) {
		padding: var(--space-3) var(--space-4);
		border-bottom: 1px solid var(--color-border);
		color: var(--color-text-muted);
	}

	.project-content :global(img) {
		max-width: 100%;
		margin: var(--space-4) auto;
		border-radius: var(--radius-md);
	}

	@media (max-width: 640px) {
		.title-row h1 {
			font-size: 2rem;
		}

		.hero {
			max-height: 300px;
		}
	}
</style>
